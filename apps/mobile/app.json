{
  "expo": {
    "name": "Product Fulfillment",
    "slug": "product-fulfillment",
    "version": "1.0.0",
    "scheme": "productfulfillment",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "ios": {
      "bundleIdentifier": "com.omegagiven.productfulfillment",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Used to photograph shipping labels and products during fulfillment.",
        "NSPhotoLibraryUsageDescription": "Used to attach product photos to customer emails.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.omegagiven.productfulfillment",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e2e8f0"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2d07c777-557c-450c-8693-aaad08ccb704"
      },
      "firebaseApiKey": "",
      "firebaseAuthDomain": "",
      "firebaseProjectId": "",
      "firebaseStorageBucket": "",
      "firebaseMessagingSenderId": "",
      "firebaseAppId": ""
    },
    "owner": "omegagiven"
  }
}
