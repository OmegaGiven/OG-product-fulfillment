{
  "expo": {
    "name": "OG Fulfillment",
    "slug": "product-fulfillment",
    "version": "1.0.0",
    "scheme": "ogfulfillment",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-document-picker"
    ],
    "ios": {
      "bundleIdentifier": "com.omegagiven.ogfulfillment",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Used to photograph shipping labels and products during fulfillment.",
        "NSPhotoLibraryUsageDescription": "Used to attach product photos to customer emails.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.omegagiven.ogfulfillment",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e2e8f0"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2d07c777-557c-450c-8693-aaad08ccb704"
      },
      "firebaseApiKey": "AIzaSyA0zgFmqkfjxbH_-hwJdEPiPq_Y9ccIYEs",
      "firebaseAuthDomain": "og-product-fulfillment.firebaseapp.com",
      "firebaseProjectId": "og-product-fulfillment",
      "firebaseStorageBucket": "og-product-fulfillment.firebasestorage.app",
      "firebaseMessagingSenderId": "577375928893",
      "firebaseAppId": "1:577375928893:web:f3081ff24e2376ba45e054"
    },
    "owner": "omegagiven"
  }
}
